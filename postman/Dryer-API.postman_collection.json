    {
      "name": "01 - Auth",
      "item": [
        {
          "name": "POST /api/v1/auth/login (Admin)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Login success', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const body = pm.response.json();",
                  "if (body && body.data && body.data.access_token) {",
                  "  pm.collectionVariables.set('token', body.data.access_token);",
                  "}",
                  "if (body && body.data && body.data.user && body.data.user.app_user_id) {",
                  "  pm.collectionVariables.set('adminUserId', String(body.data.user.app_user_id));",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{adminEmail}}\",\n  \"password\": \"{{adminPassword}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}{{apiPrefix}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["{{apiPrefix}}", "auth", "login"]
            }
          }
        },
        {
          "name": "GET /api/v1/auth/me",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}{{apiPrefix}}/auth/me",
              "host": ["{{baseUrl}}"],
              "path": ["{{apiPrefix}}", "auth", "me"]
            }
          }
        }
        ,
        {
          "name": "POST /api/v1/auth/logout",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}{{apiPrefix}}/auth/logout",
              "host": ["{{baseUrl}}"],
              "path": ["{{apiPrefix}}", "auth", "logout"]
            }
          }
        }
